configfile: "DEF.yaml"
samples = config["samples"]

compleasm_database = config["compleasm_db"]
wildcard_constraints:
    #sample ="[A-Za-z0-9_]+"
    sample = r"|".join(samples),

## benchmarking reference datasets
reference_seq = config["benchmark_path"] + "GRCh38_no_alt_analysis_set.fa"
reference_seq_idx = config["benchmark_path"] + "GRCh38_no_alt_analysis_set.fa.fai"
reference_seq2 = config["benchmark_path"] + "hs37d5.fa"
sv_ground_vcf = config["benchmark_path"] + "HG002_SVs_Tier1_v0.6.vcf.gz" 
sv_ground_bed = config["benchmark_path"] + "HG002_SVs_Tier1_v0.6.bed"
vcf_benchmark =  config["benchmark_path"] + "HG002_GRCh38_1_22_v4.2.1_benchmark.vcf.gz"
vcf_truth_bed = config["benchmark_path"] + "HG002_GRCh38_1_22_v4.2.1_benchmark_noinconsistent.bed"


## Gather the target output files (This defines which parts of the pipeline will be run)
def gather_targets():
    all_target = []
    
    ## Optional output (sniffles)
    if config["structural_variants"]:
        all_target.extend(expand("benchmarks/{sample}_truvari_sv/summary.json", sample = samples)),

    ## Default output (always turned on)
    all_target.append(expand("benchmarks/happy/{sample}_happy/{sample}_results.summary.csv", sample = samples),),

    return all_target


all_target_files = gather_targets()

## Import rules
## Default output
#include: "rules/get_readlen_hist.smk"
include: "rules/minimap_for_variants.smk"
include: "rules/deepvariant.smk"
include: "rules/happy.smk"

## Optional output
if config["structural_variants"]:
    include: "rules/sniffles.smk"
    include: "rules/truvari.smk"

rule all:
    input:
        all_target_files,